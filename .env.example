# Project Zenith — environment variables
# Copy to .env.local and fill in. ALL keys are server-side only; they are read
# exclusively inside Next.js route handlers and never shipped to the browser.
# The app degrades gracefully (cached/fallback data) when any key is absent.

# NASA (DONKI space weather, APOD, NeoWs). Get a free instant key at
# https://api.nasa.gov — or leave blank to use the public DEMO_KEY.
NASA_API_KEY=

# N2YO (visual pass predictions). Free signup: https://www.n2yo.com/api/
N2YO_API_KEY=

# OpenWeatherMap (cloud cover / visibility). Free: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# IP geolocation fallback (only used if browser geolocation is denied).
# Free: https://ipgeolocation.io
IPGEO_API_KEY=

# Space-Track (optional stretch metadata). https://www.space-track.org
SPACETRACK_USER=
SPACETRACK_PASS=

# Cesium Ion token (optional — nicer imagery). Free: https://cesium.com/ion/
# This one is PUBLIC (client-side) by design. Leave blank to use keyless
# OpenStreetMap imagery.
NEXT_PUBLIC_CESIUM_ION_TOKEN=
